# Database (Docker Compose local)
# DATABASE_URL="postgresql://prateleira:prateleira@localhost:5432/prateleira?schema=public"
# Prisma Dev example (porta muda a cada start — use a URL do `npx prisma dev`):
DATABASE_URL="postgresql://postgres:postgres@localhost:51214/prateleira?sslmode=disable"

# Auth.js
AUTH_SECRET="dev-secret-change-me-in-production-use-openssl-rand"
AUTH_URL="http://localhost:3000"

# Stripe (test mode — create products/prices in Dashboard)
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
STRIPE_PRICE_ESSENCIAL="price_replace_essencial"
STRIPE_PRICE_PROFISSIONAL="price_replace_profissional"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace_me"

# Uploads: "local" | "blob"
UPLOAD_DRIVER="local"
# Required when UPLOAD_DRIVER=blob
BLOB_READ_WRITE_TOKEN=""

# Seed: force org ACTIVE without Stripe (demos)
SEED_FORCE_ACTIVE="1"
